[Desktop Entry]
Type=Application
Name=VertexWrite
GenericName=Markdown Editor
Comment=Markdown editor with local and SSH/SFTP file browsing
Exec=HOME_VERTEXWRITE_PATH %F
Icon=HOME_VERTEXWRITE_ICON
Terminal=false
Categories=Office;Viewer;Utility;
MimeType=text/markdown;text/x-markdown;text/plain;
Keywords=markdown;md;editor;notes;ssh;sftp;
StartupNotify=true
